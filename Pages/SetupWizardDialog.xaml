<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="TubaWinUi3.Pages.SetupWizardDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    PrimaryButtonClick="OnPrimaryButtonClick"
    SecondaryButtonClick="OnSecondaryButtonClick"
    CloseButtonClick="OnCloseButtonClick">

    <ContentDialog.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <CornerRadius x:Key="DialogCornerRadius">12</CornerRadius>
        </ResourceDictionary>
    </ContentDialog.Resources>

    <Grid RowSpacing="20" MinWidth="480">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock
                x:Name="StepTitleText"
                FontSize="20"
                FontWeight="SemiBold" />
            <TextBlock
                x:Name="StepSubtitleText"
                FontSize="13"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap" />
        </StackPanel>

        <PipsPager
            x:Name="StepPager"
            Grid.Row="1"
            HorizontalAlignment="Left"
            NumberOfPages="2"
            SelectedPageIndex="0"
            Visibility="Visible" />

        <Grid Grid.Row="2" MinHeight="220">
            <StackPanel
                x:Name="Step1Content"
                Spacing="16"
                Visibility="Visible">

                <TextBlock
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="选择您喜欢的工具显示方式：" />

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        x:Name="CardModeOption"
                        Tag="Card"
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                        BorderThickness="2"
                        CornerRadius="10"
                        Tapped="LayoutOption_Tapped"
                        AutomationProperties.Name="新卡牌模式">
                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                            <Border
                                Width="56"
                                Height="56"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="12"
                                HorizontalAlignment="Center">
                                <FontIcon
                                    FontSize="28"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                    Glyph="&#xE8B7;" />
                            </Border>
                            <TextBlock
                                FontSize="15"
                                FontWeight="SemiBold"
                                HorizontalAlignment="Center"
                                Text="新卡牌模式" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                HorizontalAlignment="Center"
                                TextAlignment="Center"
                                TextWrapping="Wrap"
                                Text="卡片式布局，显示图标与详细信息" />
                        </StackPanel>
                    </Border>

                    <Border
                        x:Name="CompactModeOption"
                        Grid.Column="1"
                        Tag="Compact"
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource SubtleFillColorSecondaryBrush}"
                        BorderThickness="2"
                        CornerRadius="10"
                        Tapped="LayoutOption_Tapped"
                        AutomationProperties.Name="简洁模式">
                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                            <Border
                                Width="56"
                                Height="56"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="12"
                                HorizontalAlignment="Center">
                                <FontIcon
                                    FontSize="28"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Glyph="&#xE8FD;" />
                            </Border>
                            <TextBlock
                                FontSize="15"
                                FontWeight="SemiBold"
                                HorizontalAlignment="Center"
                                Text="简洁模式" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                HorizontalAlignment="Center"
                                TextAlignment="Center"
                                TextWrapping="Wrap"
                                Text="紧凑排列，一屏显示更多工具" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <StackPanel
                x:Name="Step2Content"
                Spacing="16"
                Visibility="Collapsed">

                <TextBlock
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="选择窗口背景材质效果：" />

                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        x:Name="BackdropMicaOption"
                        Tag="Mica"
                        Padding="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                        BorderThickness="2"
                        CornerRadius="10"
                        Tapped="BackdropOption_Tapped"
                        AutomationProperties.Name="Mica">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <Border
                                Width="80"
                                Height="52"
                                CornerRadius="8"
                                HorizontalAlignment="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Offset="0" Color="#1a1a2e" />
                                        <GradientStop Offset="0.5" Color="#16213e" />
                                        <GradientStop Offset="1" Color="#0f3460" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border
                                    Margin="6"
                                    Padding="4"
                                    Background="#99ffffff"
                                    CornerRadius="4">
                                    <TextBlock
                                        FontSize="9"
                                        Foreground="#1a1a2e"
                                        HorizontalAlignment="Center"
                                        Text="Mica" />
                                </Border>
                            </Border>
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                HorizontalAlignment="Center"
                                Text="Mica" />
                            <TextBlock
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                HorizontalAlignment="Center"
                                TextAlignment="Center"
                                TextWrapping="Wrap"
                                Text="柔和云母效果" />
                        </StackPanel>
                    </Border>

                    <Border
                        x:Name="BackdropMicaAltOption"
                        Grid.Column="1"
                        Tag="MicaAlt"
                        Padding="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource SubtleFillColorSecondaryBrush}"
                        BorderThickness="2"
                        CornerRadius="10"
                        Tapped="BackdropOption_Tapped"
                        AutomationProperties.Name="Mica Alt">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <Border
                                Width="80"
                                Height="52"
                                CornerRadius="8"
                                HorizontalAlignment="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Offset="0" Color="#2d1b69" />
                                        <GradientStop Offset="0.5" Color="#11998e" />
                                        <GradientStop Offset="1" Color="#38ef7d" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border
                                    Margin="6"
                                    Padding="4"
                                    Background="#99ffffff"
                                    CornerRadius="4">
                                    <TextBlock
                                        FontSize="9"
                                        Foreground="#2d1b69"
                                        HorizontalAlignment="Center"
                                        Text="Mica Alt" />
                                </Border>
                            </Border>
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                HorizontalAlignment="Center"
                                Text="Mica Alt" />
                            <TextBlock
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                HorizontalAlignment="Center"
                                TextAlignment="Center"
                                TextWrapping="Wrap"
                                Text="层次更丰富的云母" />
                        </StackPanel>
                    </Border>

                    <Border
                        x:Name="BackdropAcrylicOption"
                        Grid.Column="2"
                        Tag="Acrylic"
                        Padding="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource SubtleFillColorSecondaryBrush}"
                        BorderThickness="2"
                        CornerRadius="10"
                        Tapped="BackdropOption_Tapped"
                        AutomationProperties.Name="亚克力">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <Border
                                Width="80"
                                Height="52"
                                CornerRadius="8"
                                HorizontalAlignment="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Offset="0" Color="#667eea" />
                                        <GradientStop Offset="1" Color="#764ba2" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border
                                    Margin="6"
                                    Padding="4"
                                    Background="#88ffffff"
                                    CornerRadius="4">
                                    <TextBlock
                                        FontSize="9"
                                        Foreground="#764ba2"
                                        HorizontalAlignment="Center"
                                        Text="Acrylic" />
                                </Border>
                            </Border>
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                HorizontalAlignment="Center"
                                Text="亚克力" />
                            <TextBlock
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                HorizontalAlignment="Center"
                                TextAlignment="Center"
                                TextWrapping="Wrap"
                                Text="磨砂玻璃模糊效果" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</ContentDialog>
