<Page
    x:Class="TubaWinUi3.Pages.PcSetupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="0" RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Step Indicator -->
        <Border Grid.Row="0" Padding="24,16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                <!-- Step 1 -->
                <StackPanel x:Name="Step1Indicator" Orientation="Horizontal" Spacing="6">
                    <Border x:Name="Step1Circle" Width="28" Height="28" CornerRadius="14"
                            Background="{ThemeResource AccentFillColorDefaultBrush}">
                        <TextBlock Text="1" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="13" FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock x:Name="Step1Text" Text="软件安装" VerticalAlignment="Center" FontSize="13"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="SemiBold"/>
                </StackPanel>
                <FontIcon Glyph="&#xE76C;" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                          VerticalAlignment="Center"/>
                <!-- Step 2 -->
                <StackPanel x:Name="Step2Indicator" Orientation="Horizontal" Spacing="6">
                    <Border x:Name="Step2Circle" Width="28" Height="28" CornerRadius="14"
                            Background="{ThemeResource ControlFillColorSecondaryBrush}">
                        <TextBlock Text="2" Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="13" FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock x:Name="Step2Text" Text="系统优化" VerticalAlignment="Center" FontSize="13"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                </StackPanel>
                <FontIcon Glyph="&#xE76C;" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                          VerticalAlignment="Center"/>
                <!-- Step 3 -->
                <StackPanel x:Name="Step3Indicator" Orientation="Horizontal" Spacing="6">
                    <Border x:Name="Step3Circle" Width="28" Height="28" CornerRadius="14"
                            Background="{ThemeResource ControlFillColorSecondaryBrush}">
                        <TextBlock Text="3" Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="13" FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock x:Name="Step3Text" Text="烤机测试" VerticalAlignment="Center" FontSize="13"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                </StackPanel>
                <FontIcon Glyph="&#xE76C;" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                          VerticalAlignment="Center"/>
                <!-- Step 4 -->
                <StackPanel x:Name="Step4Indicator" Orientation="Horizontal" Spacing="6">
                    <Border x:Name="Step4Circle" Width="28" Height="28" CornerRadius="14"
                            Background="{ThemeResource ControlFillColorSecondaryBrush}">
                        <TextBlock Text="4" Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="13" FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock x:Name="Step4Text" Text="执行" VerticalAlignment="Center" FontSize="13"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Row="1">            <!-- Step 1: Software Install -->
            <ScrollViewer x:Name="Step1Content" Visibility="Visible" Padding="24,16">
                <StackPanel Spacing="12">
                    <TextBlock Text="选择要安装的软件" FontSize="18" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <TextBlock Text="勾选你需要的软件，稍后统一通过 winget 安装" FontSize="13"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <!-- Stats -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="StatTotal" Grid.Column="0" CornerRadius="6" Padding="12,8"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"/>
                        <Border x:Name="StatInstalled" Grid.Column="1" CornerRadius="6" Padding="12,8"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"/>
                        <Border x:Name="StatSelected" Grid.Column="2" CornerRadius="6" Padding="12,8"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"/>
                    </Grid>
                    <!-- Action bar -->
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="CategoryFilter" Grid.Column="0" HorizontalAlignment="Stretch"
                                  PlaceholderText="筛选分类" SelectionChanged="CategoryFilter_SelectionChanged"/>
                        <Button Grid.Column="1" Content="全选" Click="SelectAll_Click"/>
                        <Button Grid.Column="2" Content="取消全选" Click="DeselectAll_Click"/>
                        <Button Grid.Column="3" Content="仅选未安装" Click="SelectNotInstalled_Click"/>
                    </Grid>
                    <!-- Loading -->
                    <StackPanel x:Name="LoadingPanel" Orientation="Horizontal" Spacing="8" Visibility="Collapsed">
                        <ProgressRing IsActive="True" Width="20" Height="20"/>
                        <TextBlock Text="正在检测已安装软件..." VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <!-- Package List -->
                    <StackPanel x:Name="PackageList" Spacing="4"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Step 2: System Optimize -->
            <ScrollViewer x:Name="Step2Content" Visibility="Collapsed" Padding="24,16">
                <StackPanel Spacing="12">
                    <TextBlock Text="系统优化配置" FontSize="18" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <TextBlock Text="选择视觉体验挡位，并勾选需要的优化项" FontSize="13"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <!-- Visual Preset -->
                    <Border CornerRadius="8" Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Spacing="10">
                            <TextBlock Text="视觉体验挡位" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <StackPanel x:Name="VisualPresetPanel" Orientation="Horizontal" Spacing="24"/>
                        </StackPanel>
                    </Border>
                    <!-- Optimize Items -->
                    <StackPanel x:Name="OptimizeItemsList" Spacing="4"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Step 3: CPU Burn -->
            <Grid x:Name="Step3Content" Visibility="Collapsed" Padding="24,16" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Spacing="4">
                    <TextBlock Text="CPU 单烤机测试" FontSize="18" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <TextBlock Text="将 CPU 占用拉满 10 分钟，实时监控温度、功耗、频率" FontSize="13"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
                <!-- Controls -->
                <Grid Grid.Row="1" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="BurnTimer" Grid.Column="0" Text="00:00 / 10:00" FontSize="22" FontWeight="Bold"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                    <ComboBox x:Name="BurnDurationCombo" Grid.Column="1" HorizontalAlignment="Stretch"
                              SelectionChanged="BurnDuration_SelectionChanged">
                        <ComboBoxItem Content="3 分钟" Tag="3"/>
                        <ComboBoxItem Content="5 分钟" Tag="5"/>
                        <ComboBoxItem Content="10 分钟" Tag="10" IsSelected="True"/>
                        <ComboBoxItem Content="15 分钟" Tag="15"/>
                        <ComboBoxItem Content="30 分钟" Tag="30"/>
                    </ComboBox>
                    <Button x:Name="BurnStartBtn" Grid.Column="2" Content="开始烤机" Style="{ThemeResource AccentButtonStyle}"
                            Click="BurnStart_Click"/>
                    <Button x:Name="BurnStopBtn" Grid.Column="3" Content="停止" IsEnabled="False" Click="BurnStop_Click"/>
                </Grid>
                <!-- Chart -->
                <Border Grid.Row="2" CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="8">
                    <Canvas x:Name="BurnChart"/>
                </Border>
                <!-- Stats -->
                <Grid Grid.Row="3" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="BurnTempCard" Grid.Column="0" CornerRadius="6" Padding="10,6"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"/>
                    <Border x:Name="BurnPowerCard" Grid.Column="1" CornerRadius="6" Padding="10,6"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"/>
                    <Border x:Name="BurnClockCard" Grid.Column="2" CornerRadius="6" Padding="10,6"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"/>
                    <Border x:Name="BurnLoadCard" Grid.Column="3" CornerRadius="6" Padding="10,6"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"/>
                </Grid>
                <!-- Legend -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Border Width="12" Height="3" CornerRadius="1" Background="#FFF87171"/>
                        <TextBlock Text="温度(°C)" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Border Width="12" Height="3" CornerRadius="1" Background="#FFFBBF24"/>
                        <TextBlock Text="功耗(W)" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Border Width="12" Height="3" CornerRadius="1" Background="#FF60A5FA"/>
                        <TextBlock Text="频率(MHz)" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Border Width="12" Height="3" CornerRadius="1" Background="#FF4ADE80"/>
                        <TextBlock Text="占用(%)" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Step 4: Execute -->
            <ScrollViewer x:Name="Step4Content" Visibility="Collapsed" Padding="24,16">
                <StackPanel Spacing="12">
                    <TextBlock Text="执行清单" FontSize="18" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <TextBlock x:Name="ExecuteSummary" Text="" FontSize="13"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <!-- Action List -->
                    <StackPanel x:Name="ExecuteActionList" Spacing="4"/>
                    <!-- Progress -->
                    <StackPanel x:Name="ExecuteProgressPanel" Visibility="Collapsed" Spacing="8">
                        <ProgressBar x:Name="ExecuteProgressBar" IsIndeterminate="False" Value="0" Maximum="100"/>
                        <TextBlock x:Name="ExecuteProgressText" Text="" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <!-- Log -->
                    <Border x:Name="ExecuteLogBorder" CornerRadius="6" Padding="12" MaxHeight="200" Visibility="Collapsed"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <ScrollViewer>
                            <TextBlock x:Name="ExecuteLogText" FontFamily="Consolas" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" IsTextSelectionEnabled="True"/>
                        </ScrollViewer>
                    </Border>
                    <!-- Buttons -->
                    <Grid ColumnSpacing="12" HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="ExecuteBtn" Grid.Column="0" Content="立即执行" HorizontalAlignment="Stretch"
                                Style="{ThemeResource AccentButtonStyle}" Click="Execute_Click"/>
                        <Button x:Name="ExportBtn" Grid.Column="1" Content="导出 PowerShell 脚本" HorizontalAlignment="Stretch"
                                Click="Export_Click"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Bottom Navigation -->
        <Border Grid.Row="2" Padding="24,12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="PrevBtn" Grid.Column="1" Content="上一步" Click="Prev_Click" IsEnabled="False"/>
                <Button x:Name="NextBtn" Grid.Column="2" Content="下一步" Style="{ThemeResource AccentButtonStyle}"
                        Click="Next_Click"/>
            </Grid>
        </Border>
    </Grid>
</Page>
