<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="TubaWinUi3.Pages.ConfigManagerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="配置管理"
    PrimaryButtonText="关闭"
    DefaultButton="Primary"
    CloseButtonText="">

    <ScrollViewer MaxHeight="560" HorizontalScrollMode="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="0,4,0,0">

            <TextBlock
                FontSize="14"
                FontWeight="SemiBold"
                Opacity="0.62"
                Text="配置存储位置" />

            <Border
                Padding="16"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
                <StackPanel Spacing="12">
                    <RadioButton
                        x:Name="AppDataRadio"
                        Content="AppData (%LocalAppData%\TubaWinUi3\)"
                        Checked="LocationRadio_Checked"
                        Tag="AppData" />
                    <RadioButton
                        x:Name="AppRootRadio"
                        Content="程序根目录 (程序目录\Data\)"
                        Checked="LocationRadio_Checked"
                        Tag="AppRoot" />
                </StackPanel>
            </Border>

            <TextBlock
                FontSize="14"
                FontWeight="SemiBold"
                Opacity="0.62"
                Text="当前配置目录" />

            <Border
                Padding="16"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        x:Name="DataDirText"
                        VerticalAlignment="Center"
                        TextTrimming="CharacterEllipsis"
                        MaxLines="2"
                        TextWrapping="Wrap" />
                    <Button
                        x:Name="CopyPathButton"
                        Grid.Column="1"
                        Padding="8,4"
                        VerticalAlignment="Center"
                        Click="CopyPathButton_Click"
                        ToolTipService.ToolTip="复制路径">
                        <FontIcon FontSize="12" Glyph="&#xE8C8;" />
                    </Button>
                    <Button
                        x:Name="OpenDirButton"
                        Grid.Column="2"
                        Padding="8,4"
                        VerticalAlignment="Center"
                        Click="OpenDirButton_Click"
                        ToolTipService.ToolTip="打开文件夹">
                        <FontIcon FontSize="12" Glyph="&#xE8A7;" />
                    </Button>
                </Grid>
            </Border>

            <TextBlock x:Name="DataSizeText" Opacity="0.68" FontSize="13" />

            <Border
                Padding="0,1"
                Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <TextBlock
                FontSize="14"
                FontWeight="SemiBold"
                Opacity="0.62"
                Text="数据操作" />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="ExportButton" Click="ExportButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="12" Glyph="&#xE896;" />
                        <TextBlock Text="导出配置" />
                    </StackPanel>
                </Button>
                <Button x:Name="ImportButton" Click="ImportButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="12" Glyph="&#xE8E5;" />
                        <TextBlock Text="导入配置" />
                    </StackPanel>
                </Button>
                <Button x:Name="CleanCacheButton" Click="CleanCacheButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="12" Glyph="&#xE74D;" />
                        <TextBlock Text="清除图标缓存" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <TextBlock
                x:Name="StatusText"
                Opacity="0.68"
                FontSize="12"
                TextWrapping="Wrap" />

        </StackPanel>
    </ScrollViewer>
</ContentDialog>
