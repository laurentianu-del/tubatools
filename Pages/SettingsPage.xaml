<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TubaWinUi3.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TubaWinUi3.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Enabled"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Opacity" Value="0.62" />
            <Setter Property="Margin" Value="0,24,0,6" />
        </Style>
        <Style x:Key="IconBorderStyle" TargetType="Border">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Storyboard x:Name="DrawerOpenStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="DrawerOverlayBackground"
                Storyboard.TargetProperty="Opacity"
                From="0"
                To="1"
                Duration="0:0:0.2" />
            <DoubleAnimation
                Storyboard.TargetName="DrawerPanelTransform"
                Storyboard.TargetProperty="X"
                From="420"
                To="0"
                Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Name="DrawerCloseStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="DrawerOverlayBackground"
                Storyboard.TargetProperty="Opacity"
                From="1"
                To="0"
                Duration="0:0:0.15" />
            <DoubleAnimation
                Storyboard.TargetName="DrawerPanelTransform"
                Storyboard.TargetProperty="X"
                From="0"
                To="420"
                Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Page.Resources>

    <Grid Background="Transparent">
        <ScrollViewer
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto">
            <RelativePanel HorizontalAlignment="Stretch">
                <StackPanel
                    x:Name="ContentPanel"
                    RelativePanel.AlignHorizontalCenterWithPanel="True"
                    RelativePanel.AlignLeftWithPanel="True"
                    RelativePanel.AlignRightWithPanel="True"
                    MaxWidth="1000"
                    Spacing="2"
                    Padding="40,28,40,48">
                    <StackPanel.Transitions>
                        <TransitionCollection>
                            <RepositionThemeTransition />
                        </TransitionCollection>
                    </StackPanel.Transitions>

                    <TextBlock
                        FontSize="28"
                        FontWeight="SemiBold"
                        Text="设置" />
                    <TextBlock
                        Opacity="0.72"
                        Margin="0,0,0,16"
                        Text="管理应用外观、更新及查看关于信息。" />

                <TextBlock
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="关于" />

                <Border x:Name="SettingsAboutCard" Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Image
                            x:Name="SettingsGifImage"
                            Width="56"
                            Height="56"
                            Stretch="UniformToFill" />

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="图吧工具箱" />
                            <TextBlock Opacity="0.68" Text="基于 WinUI 3 构建的 PC 硬件工具集合" />
                            <TextBlock
                                x:Name="VersionText"
                                Opacity="0.52"
                                FontSize="12" />
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="常规" />

                <Border x:Name="SettingsUpdateCard" Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE777;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="检查更新" />
                            <TextBlock
                                x:Name="UpdateStatusText"
                                Opacity="0.68"
                                FontSize="13"
                                Text="点击检查是否有新版本" />
                        </StackPanel>

                        <Button
                            x:Name="CheckUpdateButton"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Padding="14,6"
                            Click="CheckUpdateButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="12" Glyph="&#xE777;" />
                                <TextBlock Text="检查更新" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <Border x:Name="SettingsToolsBundleCard" Style="{StaticResource SettingsCardStyle}" Visibility="Collapsed">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE896;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="工具包更新" />
                            <TextBlock
                                x:Name="ToolsBundleStatusText"
                                Opacity="0.68"
                                FontSize="13"
                                Text="点击检查工具包是否有新版本" />
                        </StackPanel>

                        <Button
                            x:Name="CheckToolsBundleButton"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Padding="14,6"
                            Click="CheckToolsBundleButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="12" Glyph="&#xE896;" />
                                <TextBlock Text="检查更新" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

<Border x:Name="SettingsThemeCard" Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE771;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="应用主题" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                Text="选择浅色、深色或跟随系统" />
                        </StackPanel>

                        <ComboBox
                            x:Name="ThemeComboBox"
                            Grid.Column="2"
                            MinWidth="120"
                            SelectionChanged="ThemeComboBox_SelectionChanged" />
                    </Grid>
                </Border>

                <Border x:Name="SettingsCompactModeCard" Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE8FD;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="简洁列表模式" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                TextWrapping="Wrap"
                                Text="原版图吧工具箱的样式" />
                        </StackPanel>

                        <ToggleSwitch
                            x:Name="CompactModeToggle"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Toggled="CompactModeToggle_Toggled" />
                    </Grid>
                </Border>

                <Border x:Name="SettingsBrandLogoCard" Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xEEA3;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="显示品牌 Logo" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                TextWrapping="Wrap"
                                Text="在硬件信息页面的处理器和显卡行前显示品牌图标" />
                        </StackPanel>

                        <ToggleSwitch
                            x:Name="BrandLogoToggle"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Toggled="BrandLogoToggle_Toggled" />
                    </Grid>
                </Border>

                <Border x:Name="SettingsHardwareFitScreenCard" Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE799;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="硬件信息一屏显示" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                TextWrapping="Wrap"
                                Text="自动缩放使所有硬件信息在一屏内显示，关闭后允许滚动浏览" />
                        </StackPanel>

                        <ToggleSwitch
                            x:Name="HardwareFitScreenToggle"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Toggled="HardwareFitScreenToggle_Toggled" />
                    </Grid>
                </Border>

                <Border x:Name="SettingsHardwareMultiDeviceNewLineCard" Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE8FD;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="多设备换行显示" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                TextWrapping="Wrap"
                                Text="当存在多个显卡、硬盘等设备时，每个设备单独一行显示" />
                        </StackPanel>

                        <ToggleSwitch
                            x:Name="HardwareMultiDeviceNewLineToggle"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Toggled="HardwareMultiDeviceNewLineToggle_Toggled" />
                    </Grid>
                </Border>

                <Border x:Name="SettingsDefaultPageCard" Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE80F;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="默认启动页面" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                TextWrapping="Wrap"
                                Text="选择应用启动后默认打开的页面" />
                        </StackPanel>

                        <ComboBox
                            x:Name="DefaultPageComboBox"
                            Grid.Column="2"
                            MinWidth="120"
                            SelectionChanged="DefaultPageComboBox_SelectionChanged" />
                    </Grid>
                </Border>

                <Border x:Name="SettingsFastModeCard" Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE945;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="快速模式" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                TextWrapping="Wrap"
                                Text="禁用所有动画，提升响应速度" />
                        </StackPanel>

                        <ToggleSwitch
                            x:Name="FastModeToggle"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Toggled="FastModeToggle_Toggled" />
                    </Grid>
                </Border>

                <Border x:Name="SettingsWatermarkCard" Style="{StaticResource SettingsCardStyle}">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource IconBorderStyle}">
                                <FontIcon FontSize="18" Glyph="&#xE8B9;" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="截图水印" />
                                <TextBlock
                                    Opacity="0.68"
                                    FontSize="13"
                                    TextWrapping="Wrap"
                                    Text="硬件信息截图时在右下角添加水印" />
                            </StackPanel>

                            <ToggleSwitch
                                x:Name="WatermarkToggle"
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                Toggled="WatermarkToggle_Toggled" />
                        </Grid>

                        <Border
                            Grid.Row="1"
                            x:Name="WatermarkDivider"
                            Padding="0,1"
                            Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                        <Grid Grid.Row="2" ColumnSpacing="16" x:Name="WatermarkDetailPanel">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource IconBorderStyle}">
                                <FontIcon FontSize="18" Glyph="&#xE8D2;" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="水印文字" />
                                <TextBlock
                                    Opacity="0.68"
                                    FontSize="13"
                                    TextWrapping="Wrap"
                                    Text="自定义截图水印显示的文字" />
                            </StackPanel>

                            <TextBox
                                x:Name="WatermarkTextBox"
                                Grid.Column="2"
                                MinWidth="160"
                                MaxWidth="240"
                                PlaceholderText="图吧工具箱"
                                TextChanged="WatermarkTextBox_TextChanged" />
                        </Grid>

                        <Grid Grid.Row="3" ColumnSpacing="16" x:Name="WatermarkFontPanel">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource IconBorderStyle}">
                                <FontIcon FontSize="18" Glyph="&#xE9F5;" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="水印字体" />
                                <TextBlock
                                    Opacity="0.68"
                                    FontSize="13"
                                    TextWrapping="Wrap"
                                    Text="自定义截图水印使用的字体" />
                            </StackPanel>

                            <ComboBox
                                x:Name="WatermarkFontComboBox"
                                Grid.Column="2"
                                MinWidth="160"
                                SelectionChanged="WatermarkFontComboBox_SelectionChanged" />
                        </Grid>
                    </Grid>
                </Border>

                <Border x:Name="SettingsRememberWindowCard" Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE784;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="记住窗口位置和大小" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                TextWrapping="Wrap"
                                Text="关闭后下次启动将居中显示，避免多显示器断开后窗口位置异常" />
                        </StackPanel>

                        <ToggleSwitch
                            x:Name="RememberWindowToggle"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Toggled="RememberWindowToggle_Toggled" />
                    </Grid>
                </Border>

                <TextBlock
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="配置管理" />

                <Border x:Name="SettingsConfigManagerCard" Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE912;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="配置管理" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                TextWrapping="Wrap"
                                Text="管理配置文件的存储位置、导出和导入" />
                        </StackPanel>

                        <Button
                            x:Name="ConfigManagerButton"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Padding="14,6"
                            Click="ConfigManagerButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="12" Glyph="&#xE9D9;" />
                                <TextBlock Text="管理" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <TextBlock
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="硬件监控" />

                <Border x:Name="SettingsCpuzDataSourceCard" Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xEEA1;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="硬件信息数据源" />
                            <TextBlock
                                x:Name="CpuzDataSourceStatusText"
                                Opacity="0.68"
                                FontSize="13"
                                TextWrapping="Wrap"
                                Text="使用 CPU-Z 读取真实硬件信息，防止厂商伪造" />
                        </StackPanel>

                        <Button
                            x:Name="CpuzDataSourceButton"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Padding="14,6"
                            Click="CpuzDataSourceButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon x:Name="CpuzDataSourceIcon" FontSize="12" Glyph="&#xEEA1;" />
                                <TextBlock x:Name="CpuzDataSourceButtonText" Text="切换" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <TextBlock
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="AI 服务" />

                <Border x:Name="SettingsAiEndpointCard" Style="{StaticResource SettingsCardStyle}">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource IconBorderStyle}">
                                <FontIcon FontSize="18" Glyph="&#xE945;" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="AI 服务配置" />
                                <TextBlock
                                    x:Name="AiConfigStatusText"
                                    Opacity="0.68"
                                    FontSize="13"
                                    TextWrapping="Wrap"
                                    Text="配置 OpenAI 兼容 API，启用 AI 智能功能" />
                            </StackPanel>
                        </Grid>

                        <Border
                            Grid.Row="1"
                            Padding="0,1"
                            Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                        <Grid Grid.Row="2" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource IconBorderStyle}">
                                <FontIcon FontSize="18" Glyph="&#xE774;" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="API 地址" />
                                <TextBlock
                                    Opacity="0.68"
                                    FontSize="13"
                                    TextWrapping="Wrap"
                                    Text="OpenAI 兼容 API 的 Base URL" />
                            </StackPanel>

                            <TextBox
                                x:Name="AiEndpointTextBox"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                MinWidth="280"
                                MaxWidth="360"
                                PlaceholderText="https://api.openai.com/v1"
                                TextChanged="AiEndpointTextBox_TextChanged" />
                        </Grid>

                        <Grid Grid.Row="3" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource IconBorderStyle}">
                                <FontIcon FontSize="18" Glyph="&#xE943;" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="模型名" />
                                <TextBlock
                                    Opacity="0.68"
                                    FontSize="13"
                                    TextWrapping="Wrap"
                                    Text="使用的模型标识符" />
                            </StackPanel>

                            <TextBox
                                x:Name="AiModelTextBox"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                MinWidth="280"
                                MaxWidth="360"
                                PlaceholderText="gpt-4o"
                                TextChanged="AiModelTextBox_TextChanged" />
                        </Grid>

                        <Grid Grid.Row="4" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource IconBorderStyle}">
                                <FontIcon FontSize="18" Glyph="&#xE72E;" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="API Key" />
                                <TextBlock
                                    Opacity="0.68"
                                    FontSize="13"
                                    TextWrapping="Wrap"
                                    Text="API 密钥，将安全保存在本地" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <PasswordBox
                                    x:Name="AiApiKeyBox"
                                    MinWidth="200"
                                    MaxWidth="280"
                                    PlaceholderText="sk-..."
                                    PasswordChanged="AiApiKeyBox_PasswordChanged" />
