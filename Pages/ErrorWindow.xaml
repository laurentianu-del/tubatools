<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="TubaWinUi3.Pages.ErrorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Padding="32,28,32,20" ColumnSpacing="16"
              Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Width="56" Height="56"
                    Background="#33FF4444"
                    CornerRadius="14">
                <FontIcon FontSize="28" Foreground="#FF4444" Glyph="&#xE783;" />
            </Border>

            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                <TextBlock FontSize="26" FontWeight="SemiBold" Text="出现了意外错误" />
                <TextBlock Opacity="0.68" FontSize="13" TextWrapping="Wrap"
                           Text="应用遇到了一个未处理的异常，你可以复制详细信息并提交 Issue 帮助我们改进。" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" HorizontalScrollMode="Disabled"
                      VerticalScrollBarVisibility="Auto" Padding="32,20,32,8">
            <StackPanel Spacing="12" MaxWidth="860">

                <Border Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="10">
                    <StackPanel Spacing="12">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <FontIcon FontSize="14" Glyph="&#xE946;" Opacity="0.68" />
                                <TextBlock FontSize="14" FontWeight="SemiBold" Opacity="0.78" Text="异常详情" />
                            </StackPanel>
                            <Button x:Name="CopyButton" Grid.Column="1"
                                    Padding="10,4" Click="CopyButton_Click"
                                    ToolTipService.ToolTip="复制到剪贴板"
                                    CornerRadius="6">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="12" Glyph="&#xE8C8;" />
                                    <TextBlock x:Name="CopyButtonText" FontSize="12" Text="复制" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <ScrollViewer MaxHeight="220" HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="ErrorText"
                                       FontFamily="Cascadia Code, Consolas"
                                       FontSize="12" Opacity="0.82"
                                       TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <Border Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="10">
                    <StackPanel Spacing="8">
                        <Grid x:Name="SysInfoHeader" ColumnSpacing="8" Padding="0,2"
                              PointerPressed="SysInfoHeader_Click">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <FontIcon x:Name="SysInfoChevron" FontSize="10" Glyph="&#xE70D;" Opacity="0.5" />
                                <FontIcon FontSize="14" Glyph="&#xE950;" Opacity="0.68" />
                                <TextBlock FontSize="14" FontWeight="SemiBold" Opacity="0.78" Text="系统信息" />
                                <TextBlock x:Name="SysInfoSummary" FontSize="12" Opacity="0.5"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <Button x:Name="CopySysInfoButton" Grid.Column="1"
                                    Padding="10,4" Click="CopySysInfoButton_Click"
                                    ToolTipService.ToolTip="复制系统信息"
                                    CornerRadius="6">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="12" Glyph="&#xE8C8;" />
                                    <TextBlock x:Name="CopySysInfoButtonText" FontSize="12" Text="复制" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <ScrollViewer x:Name="SysInfoContent"
                                      MaxHeight="200" HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      Visibility="Collapsed">
                            <TextBlock x:Name="SysInfoText"
                                       FontFamily="Cascadia Code, Consolas"
                                       FontSize="12" Opacity="0.82"
                                       TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <Border Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="10">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <FontIcon FontSize="14" Glyph="&#xE8BD;" Opacity="0.68" />
                            <TextBlock FontSize="14" FontWeight="SemiBold" Opacity="0.78" Text="复现步骤" />
                        </StackPanel>
                        <TextBlock Opacity="0.55" FontSize="12" TextWrapping="Wrap"
                                   Text="请描述你遇到此错误时的操作步骤，帮助我们定位问题。" />
                        <TextBox x:Name="ReproStepsBox"
                                 PlaceholderText="例如：1. 打开硬件信息页&#x0a;2. 点击刷新按钮&#x0a;3. 应用崩溃"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="80" MaxHeight="160"
                                 FontSize="13"
                                 CornerRadius="8" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="32,16,32,20"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                <Button x:Name="CloseWindowButton" Padding="20,10" Click="CloseWindowButton_Click"
                        CornerRadius="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE711;" />
                        <TextBlock Text="关闭" />
                    </StackPanel>
                </Button>
                <Button x:Name="RestartButton" Padding="20,10" Click="RestartButton_Click"
                        CornerRadius="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE72C;" />
                        <TextBlock Text="重启应用" />
                    </StackPanel>
                </Button>
                <Button x:Name="ReportButton" Padding="20,10" Click="ReportButton_Click"
                        CornerRadius="8"
                        Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE8F1;" />
                        <TextBlock Text="提交 GitHub Issue" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

    </Grid>
</Window>
