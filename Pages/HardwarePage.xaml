<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TubaWinUi3.Pages.HardwarePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <ScrollViewer>
            <Grid MaxWidth="1180" Padding="28,18,28,28" RowSpacing="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="30"
                            FontWeight="SemiBold"
                            Text="硬件信息" />
                        <TextBlock
                            Opacity="0.72"
                            Text="汇总本机型号、系统和关键硬件参数。" />
                    </StackPanel>

                    <Button
                        Grid.Column="1"
                        Padding="14,7"
                        Click="RefreshButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE72C;" />
                            <TextBlock Text="刷新" />
                        </StackPanel>
                    </Button>
                </Grid>

                <Grid Grid.Row="1" ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource MetricCardStyle}">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Width="44"
                                Height="44"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="8">
                                <FontIcon FontSize="22" Glyph="&#xE7F4;" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="5">
                                <TextBlock Opacity="0.68" Text="型号信息" />
                                <TextBlock
                                    x:Name="ModelText"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Width="44"
                                Height="44"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="8">
                                <FontIcon FontSize="22" Glyph="&#xE782;" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="5">
                                <TextBlock Opacity="0.68" Text="系统信息" />
                                <TextBlock
                                    x:Name="SystemText"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Width="44"
                                Height="44"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="8">
                                <FontIcon FontSize="22" Glyph="&#xE9D9;" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="5">
                                <TextBlock Opacity="0.68" Text="运行时间" />
                                <TextBlock
                                    x:Name="UptimeText"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="2" Style="{StaticResource MetricCardStyle}">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="详细信息" />

                        <ItemsRepeater x:Name="DetailsRepeater" Grid.Row="1">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinHeight="42" Padding="0,7" ColumnSpacing="20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Opacity="0.68"
                                            Text="{Binding Label}"
                                            VerticalAlignment="Top" />
                                        <TextBlock
                                            Grid.Column="1"
                                            FontWeight="SemiBold"
                                            Text="{Binding Value}"
                                            TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <ProgressRing
            x:Name="LoadingRing"
            Width="42"
            Height="42"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsActive="False"
            Visibility="Collapsed" />

        <InfoBar
            x:Name="StatusBar"
            Margin="28"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            IsClosable="True"
            IsOpen="False" />
    </Grid>
</Page>
