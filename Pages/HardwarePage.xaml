<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TubaWinUi3.Pages.HardwarePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
        </Style>
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <ScrollViewer Padding="24,16,24,24">
            <StackPanel Spacing="14">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="30"
                            FontWeight="SemiBold"
                            Text="硬件检测" />
                        <TextBlock
                            Opacity="0.72"
                            Text="设备档案、实时传感器、负载、功耗、温度、频率和 FPS 一页看全。" />
                    </StackPanel>

                    <StackPanel
                        Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">
                        <ComboBox
                            x:Name="RefreshIntervalBox"
                            MinWidth="92"
                            SelectedIndex="1"
                            SelectionChanged="RefreshIntervalBox_SelectionChanged"
                            ToolTipService.ToolTip="实时数据刷新间隔">
                            <ComboBoxItem Content="0.5 秒" />
                            <ComboBoxItem Content="1 秒" />
                            <ComboBoxItem Content="2 秒" />
                            <ComboBoxItem Content="5 秒" />
                        </ComboBox>
                        <Button Click="RefreshButton_Click" ToolTipService.ToolTip="刷新硬件档案">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="15" Glyph="&#xE72C;" />
                                <TextBlock Text="刷新" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <InfoBar
                    x:Name="DriverWarning"
                    IsClosable="False"
                    IsOpen="False"
                    Message="CPU 温度、功耗、频率等低层传感器需要 PawnIO 驱动。点一下自动下载并静默安装。"
                    Severity="Warning"
                    Title="需要安装监控驱动">
                    <InfoBar.ActionButton>
                        <Button
                            x:Name="InstallDriverButton"
                            Click="InstallDriverButton_Click"
                            Content="自动安装" />
                    </InfoBar.ActionButton>
                </InfoBar>

                <Border Style="{StaticResource PanelStyle}">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="实时监控" />
                                <TextBlock
                                    x:Name="MonitorStatusText"
                                    Opacity="0.68"
                                    Text="正在初始化传感器..." />
                            </StackPanel>
                            <StackPanel
                                Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="10"
                                VerticalAlignment="Center">
                                <ToggleSwitch
                                    x:Name="FpsToggle"
                                    Header="FPS"
                                    OffContent="关闭"
                                    OnContent="开启"
                                    Toggled="FpsToggle_Toggled" />
                                <ComboBox
                                    x:Name="FpsProcessBox"
                                    MinWidth="220"
                                    IsEnabled="False"
                                    PlaceholderText="自动选择游戏/渲染进程"
                                    SelectionChanged="FpsProcessBox_SelectionChanged" />
                            </StackPanel>
                        </Grid>

                        <ItemsRepeater x:Name="MetricRepeater" Grid.Row="1">
                            <ItemsRepeater.Layout>
                                <UniformGridLayout
                                    MinColumnSpacing="10"
                                    MinItemWidth="220"
                                    MinRowSpacing="10" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        MinHeight="154"
                                        Padding="14"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <Grid RowSpacing="8">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border
                                                    Width="34"
                                                    Height="34"
                                                    Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                                                    CornerRadius="8">
                                                    <FontIcon FontSize="17" Glyph="{Binding Glyph}" />
                                                </Border>
                                                <TextBlock
                                                    Grid.Column="1"
                                                    FontSize="15"
                                                    FontWeight="SemiBold"
                                                    Text="{Binding Title}"
                                                    TextTrimming="CharacterEllipsis"
                                                    VerticalAlignment="Center" />
                                            </Grid>
                                            <TextBlock
                                                Grid.Row="1"
                                                FontSize="28"
                                                FontWeight="SemiBold"
                                                Text="{Binding Primary}"
                                                TextWrapping="NoWrap" />
                                            <StackPanel Grid.Row="2" Spacing="2">
                                                <TextBlock
                                                    Opacity="0.78"
                                                    Text="{Binding Secondary}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    Opacity="0.78"
                                                    Text="{Binding Tertiary}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="3" Spacing="4">
                                                <ProgressBar
                                                    Maximum="100"
                                                    Minimum="0"
                                                    Value="{Binding Progress}" />
                                                <TextBlock
                                                    FontSize="12"
                                                    Opacity="0.62"
                                                    Text="{Binding ProgressText}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </Grid>
                </Border>

                <Border Style="{StaticResource PanelStyle}">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="硬件档案" />
                                <TextBlock
                                    x:Name="ProfileStatusText"
                                    Opacity="0.68"
                                    Text="正在读取 WMI 硬件信息..." />
                            </StackPanel>
                            <ProgressRing
                                x:Name="ProfileLoadingRing"
                                Grid.Column="1"
                                Width="28"
                                Height="28"
                                IsActive="False"
                                Visibility="Collapsed" />
                        </Grid>

                        <ItemsRepeater x:Name="ProfileRepeater" Grid.Row="1">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="0,0,0,6"
                                        Padding="12,10"
                                        Background="{ThemeResource SubtleFillColorTransparentBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Tapped="ProfileItem_Tapped"
                                        ToolTipService.ToolTip="点击复制">
                                        <Grid ColumnSpacing="14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Opacity="0.68"
                                                Text="{Binding Label}"
                                                VerticalAlignment="Center" />
                                            <TextBlock
                                                Grid.Column="1"
                                                FontWeight="SemiBold"
                                                Text="{Binding Value}"
                                                TextWrapping="Wrap"
                                                VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <InfoBar
            x:Name="StatusBar"
            Margin="24"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            IsClosable="True"
            IsOpen="False" />
    </Grid>
</Page>
